# Database
DATABASE_URL="postgresql://user:password@localhost:5432/neoserv_db?schema=public"

# Server
PORT=4000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000
MOBILE_APP_URL=exp://localhost:19000

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production
JWT_REFRESH_EXPIRES_IN=7d

# Stripe
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# PayPal
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_client_secret
PAYPAL_MODE=sandbox

# Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=neoserv@yourdomain.com

# File Upload
MAX_FILE_SIZE=10485760
UPLOAD_PATH=./public/uploads

# GPS
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# Admin
ADMIN_EMAIL=admin@neoserv.com
ADMIN_PASSWORD=Admin123!

# ==========================================
# MODULE SOURCING & DROPSHIPPING (IA)
# ==========================================

# IA (obligatoire pour l'enrichissement des fiches et le chatbot)
ANTHROPIC_API_KEY=sk-ant-...
AI_IMPORT_MODEL=claude-haiku-4-5-20251001
CHATBOT_MODEL=claude-haiku-4-5-20251001
CLEANUP_MODEL=claude-haiku-4-5-20251001

# AliExpress Open Platform (open.aliexpress.com) — API officielle dropshipping
ALIEXPRESS_APP_KEY=
ALIEXPRESS_APP_SECRET=
ALIEXPRESS_ACCESS_TOKEN=
ALIEXPRESS_SHIP_TO=FR

# CJ Dropshipping (developers.cjdropshipping.com) — API officielle v2
CJ_EMAIL=
CJ_API_KEY=
CJ_LOGISTIC_NAME=CJPacket Ordinary
CJ_FROM_COUNTRY=CN

# Mode simulation : teste tout le pipeline SANS clés fournisseur (données factices)
SOURCING_MOCK=0

# Moteur de prix : marge par défaut si aucune règle en base (%)
DROPSHIP_DEFAULT_MARGIN_PCT=120

# Synchronisation stock/prix planifiée
DROPSHIP_SYNC_ENABLED=0
DROPSHIP_SYNC_CRON=0 */6 * * *
DROPSHIP_SYNC_HIDE_OOS=1

# Auto-fulfillment (commandes fournisseurs)
DROPSHIP_FULFILL_ENABLED=0
DROPSHIP_FULFILL_CRON=*/10 * * * *
# ⚠ DROPSHIP_AUTO_PLACE=1 passe de VRAIES commandes payantes chez les fournisseurs.
# Laissez à 0 tant que vous n'avez pas validé le circuit en conditions réelles.
DROPSHIP_AUTO_PLACE=0

# Coordonnées affichées par l'assistant client
SHOP_CONTACT_PHONE=0690 97 37 10
SHOP_CONTACT_EMAIL=contact@neocom.com
